# ─────────────────────────────────────────────────────────
# Syndra — Environment Variables
# Copy to .env and fill in your values.
# All API keys are OPTIONAL — the app uses mock data when missing.
# ─────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────
APP_NAME=Syndra
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database (Supabase / PostgreSQL) ────────────────────
# Ensure you add "+asyncpg" after "postgresql" in your Supabase connection string.
DATABASE_URL=postgresql+asyncpg://postgres.xyz123:yourPasswordHere@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Redis (Upstash) ─────────────────────────────────────
# Use the rediss:// URL from Upstash
REDIS_URL=rediss://default:yourPasswordHere@terrific-koala-12345.upstash.io:30000

# ── Auth ──────────────────────────────────────────────
SECRET_KEY=CHANGE-ME-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── News API Keys (all optional — mock fallback) ─────
NEWSAPI_KEY=
GUARDIAN_API_KEY=
GNEWS_API_KEY=
NYT_API_KEY=
MEDIASTACK_API_KEY=
CURRENTS_API_KEY=
WORLDBANK_API_KEY=

# ── AI / Hugging Face (optional — mock fallback) ─────
HF_API_TOKEN=

# ── Observability (optional) ─────────────────────────
SENTRY_DSN=
