# ─────────────────────────────────────────────────────────
# Syndra — Environment Variables
# Copy to .env and fill in your values.
# All API keys are OPTIONAL — the app uses mock data when missing.
# ─────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────
APP_NAME=Syndra
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://syndra:syndra@localhost:5432/syndra

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────
SECRET_KEY=CHANGE-ME-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── News API Keys (all optional — mock fallback) ─────
NEWSAPI_KEY=
GUARDIAN_API_KEY=
GNEWS_API_KEY=
NYT_API_KEY=
MEDIASTACK_API_KEY=
CURRENTS_API_KEY=
WORLDBANK_API_KEY=

# ── AI / Hugging Face (optional — mock fallback) ─────
HF_API_TOKEN=

# ── Observability (optional) ─────────────────────────
SENTRY_DSN=
